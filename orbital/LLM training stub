const flat=document.getElementById("flat"), fx=flat.getContext("2d");
const epochEl=document.getElementById("epoch");
const SEEDS=[7,59,46,98,85,111];   // first seed chosen for clean arrow parallelism
let seedTick=0;
const phys={ stat:null, nodes:[], epoch:0, total:620, running:false };
const FLAT_ARROWS=[["king","queen"],["man","woman"],["son","daughter"]];

function sizeFlat(){
  const dpr=Math.min(devicePixelRatio||1,2);
  flat.width=innerWidth*dpr; flat.height=innerHeight*dpr;
  flat.style.width=innerWidth+"px"; flat.style.height=innerHeight+"px";
  fx.setTransform(dpr,0,0,dpr,0,0);
}
sizeFlat(); addEventListener("resize",sizeFlat);

function bounds(){
  const L=railWTarget()+60;
  return {L, R:innerWidth-60, T:80, B:innerHeight-100,
          cx:(L+innerWidth-60)/2, cy:innerHeight*0.46,
          W:innerWidth-60-L };
}
function spawnNode(w,r,bd){ return {w, x:bd.L+r()*bd.W, y:bd.T+r()*(bd.B-bd.T), vx:0, vy:0}; }

function startSettle(){
  const bd=bounds(), r=mulberry32(SEEDS[(seedTick++)%SEEDS.length]);
  phys.stat=buildStats(BASE_TRACKED, BASE_SENTENCES);
  phys.nodes=BASE_TRACKED.map(w=>spawnNode(w,r,bd));
  phys.epoch=0; phys.total=620; phys.running=true;
  if(reduceMotion){ for(let k=0;k<800;k++) stepPhys(1); finishPhys(); }
}
function startCrowd(rescatter){
  const bd=bounds(), r=mulberry32(200+(seedTick++)*7);
  phys.stat=buildStats(FULL_TRACKED, BASE_SENTENCES.concat(EXTRA_SENTENCES));
  const have=Object.fromEntries(phys.nodes.map(n=>[n.w,n]));
  phys.nodes=FULL_TRACKED.map(w=>{
    if(have[w] && !rescatter) return have[w];
    if(have[w] && rescatter && BASE_TRACKED.includes(w)) return have[w];
    return spawnNode(w,r,bd);
  });
  phys.epoch=0; phys.total=420; phys.running=true;
  if(reduceMotion){ for(let k=0;k<600;k++) stepPhys(1); finishPhys(); }
}
function ensureFlatState(full){
  if(!phys.nodes.length){ startSettle(); for(let k=0;k<800;k++) stepPhys(1); finishPhys(); }
  if(full && phys.nodes.length<FULL_TRACKED.length){
    startCrowd(false); for(let k=0;k<600;k++) stepPhys(1); finishPhys();
  }
}
function stepPhys(alpha){
  const bd=bounds(), sim=phys.stat.sim, idx=phys.stat.idx, ns=phys.nodes, n=ns.length;
  const DN=64, DF=Math.min(bd.W, innerHeight*1.3)*0.46;
  for(let i=0;i<n;i++) for(let j=i+1;j<n;j++){
    const a=ns[i], b=ns[j];
    let dx=b.x-a.x, dy=b.y-a.y, dist=Math.hypot(dx,dy)||0.01;
    const s=sim[idx[a.w]][idx[b.w]];
    const target=DF-(DF-DN)*Math.pow(s,0.6);
    let f=(dist-target)*0.0011*(0.22+s);
    if(dist<50) f-=(50-dist)*0.05;
    const ux=dx/dist, uy=dy/dist;
    a.vx+=f*ux*alpha; a.vy+=f*uy*alpha; b.vx-=f*ux*alpha; b.vy-=f*uy*alpha;
  }
  for(const nd of ns){
    nd.vx+=(bd.cx-nd.x)*0.0012*alpha; nd.vy+=(bd.cy-nd.y)*0.0012*alpha;
    nd.vx*=0.86; nd.vy*=0.86; nd.x+=nd.vx; nd.y+=nd.vy;
    nd.x=Math.max(bd.L,Math.min(bd.R,nd.x)); nd.y=Math.max(bd.T,Math.min(bd.B,nd.y));
  }
}
function finishPhys(){ phys.running=false; phys.epoch=phys.total; }
function nodeByWord(w){ return phys.nodes.find(n=>n.w===w); }

function drawFlat(){
  if(phys.running && !reduceMotion){ fx.fillStyle="rgba(7,7,13,0.32)"; fx.fillRect(0,0,innerWidth,innerHeight); }
  else fx.clearRect(0,0,innerWidth,innerHeight);
  fx.textAlign="center";
  for(const n of phys.nodes){
    const g=fx.createRadialGradient(n.x,n.y,0,n.x,n.y,13);
    g.addColorStop(0,"rgba(217,160,91,0.5)"); g.addColorStop(1,"rgba(217,160,91,0)");
    fx.fillStyle=g; fx.beginPath(); fx.arc(n.x,n.y,13,0,7); fx.fill();
    fx.fillStyle="#eae4d3"; fx.beginPath(); fx.arc(n.x,n.y,2.2,0,7); fx.fill();
    fx.font="14px Palatino, Georgia, serif";
    fx.fillStyle="rgba(234,228,211,0.92)";
    fx.fillText(n.w, n.x, n.y-9);
  }
  if(cur===4){
    for(const [a,b] of FLAT_ARROWS){
      const A=nodeByWord(a), B=nodeByWord(b); if(!A||!B) continue;
      drawArrow2D(A.x,A.y,B.x,B.y);
    }
  }
}
function drawArrow2D(x1,y1,x2,y2){
  const dx=x2-x1, dy=y2-y1, len=Math.hypot(dx,dy); if(len<8) return;
  const ux=dx/len, uy=dy/len;
  const sx=x1+ux*12, sy=y1+uy*12, ex=x2-ux*14, ey=y2-uy*14;
  fx.save();
  fx.strokeStyle="rgba(217,160,91,0.9)"; fx.fillStyle="rgba(217,160,91,0.9)";
  fx.shadowColor="rgba(217,160,91,0.8)"; fx.shadowBlur=10; fx.lineWidth=2;
  fx.beginPath(); fx.moveTo(sx,sy); fx.lineTo(ex,ey); fx.stroke();
  const hx=ex, hy=ey, s=8;
  fx.beginPath();
  fx.moveTo(hx+ux*s, hy+uy*s);
  fx.lineTo(hx-uy*s*0.55, hy+ux*s*0.55);
  fx.lineTo(hx+uy*s*0.55, hy-ux*s*0.55);
  fx.closePath(); fx.fill();
  fx.restore();
}
function flatLoop(){
  if(cur<3||cur>5) return;
  if(phys.running){
    const alpha=0.25+Math.max(0,1-phys.epoch/phys.total);
    stepPhys(alpha); phys.epoch++;
    epochEl.innerHTML=`settling · step <b>${Math.min(phys.epoch,phys.total)}</b> / ${phys.total}`;
    if(phys.epoch>=phys.total){ finishPhys();
      epochEl.innerHTML="settled · <b>nobody placed them</b>"; }
  } else if(!epochEl.textContent) epochEl.innerHTML="settled · <b>nobody placed them</b>";
  drawFlat();
  requestAnimationFrame(flatLoop);
}
onEnter[3]=()=>{ if(phys.nodes.length!==BASE_TRACKED.length) startSettle();
  epochEl.innerHTML=""; requestAnimationFrame(flatLoop); };
onEnter[4]=()=>{ ensureFlatState(false); epochEl.innerHTML="settled · <b>nobody placed them</b>";
  requestAnimationFrame(flatLoop); };
onEnter[5]=()=>{ ensureFlatState(false);
  if(phys.nodes.length<FULL_TRACKED.length) startCrowd(false);
  requestAnimationFrame(flatLoop); };

