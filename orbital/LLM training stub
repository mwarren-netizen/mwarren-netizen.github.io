<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Shape of Meaning — How Latent Space Emerges</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<style>
  /* ============ DESIGN TOKENS ============
     night #07070d · rail #0a0913 · ink #eae4d3 · amber #d9a05b
     slate #7f9bb3 · rose #c4798a
     Display: Palatino (scholarly humanist serif) · Utility: tracked small-caps sans
  */
  :root{
    --night:#07070d; --railbg:#0a0913; --ink:#eae4d3; --ink-dim:#9a937f;
    --amber:#d9a05b; --slate:#7f9bb3; --rose:#c4798a;
    --rail: clamp(290px, 28vw, 390px);
    --serif: Palatino, "Palatino Linotype", "Book Antiqua", Georgia, serif;
    --sans: ui-sans-serif, system-ui, "Segoe UI", Helvetica, Arial, sans-serif;
  }
  body.clean{ --rail: 0px; }
  *{ box-sizing:border-box; margin:0; padding:0; }
  html,body{ height:100%; }
  body{
    background: radial-gradient(120% 90% at 60% 10%, #0b0a16 0%, var(--night) 60%, #050509 100%);
    color:var(--ink); font-family:var(--serif); overflow:hidden;
    -webkit-font-smoothing:antialiased;
  }

  /* ============ LAYERS ============ */
  #webgl{ position:fixed; inset:0; z-index:0; opacity:0; transition:opacity 1.2s ease; cursor:grab; }
  #webgl.on{ opacity:1; }
  #webgl.dragging{ cursor:grabbing; }
  #flat{ position:fixed; inset:0; z-index:1; pointer-events:none; opacity:0; transition:opacity 1s ease; }
  #flat.on{ opacity:1; }
  #stage{ position:fixed; inset:0; z-index:2; pointer-events:none; }

  /* ============ BEATS ============ */
  .beat{
    position:absolute; top:0; bottom:0; left:var(--rail); right:0;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    opacity:0; pointer-events:none; transition:opacity .9s ease, left .55s ease;
    padding:4vh 4vw 10vh;
  }
  .beat.active{ opacity:1; }
  .beat.active .hoverable{ pointer-events:auto; }

  /* ============ CAPTION RAIL ============ */
  #rail{
    position:fixed; left:0; top:0; bottom:0; width:var(--rail); z-index:10;
    background:var(--railbg); border-right:1px solid rgba(234,228,211,.09);
    transition:width .55s ease, opacity .45s ease; overflow:hidden;
  }
  body.clean #rail{ opacity:0; }
  .railcard{
    position:fixed; left:0; top:0; bottom:0; width:clamp(290px, 28vw, 390px); z-index:11;
    display:flex; flex-direction:column; justify-content:center;
    padding:6vh 34px 10vh; pointer-events:none;
    transition:opacity .45s ease;
  }
  body.clean .railcard{ opacity:0 !important; }
  .eyebrow{
    font-family:var(--sans); font-size:10.5px; letter-spacing:.4em; text-transform:uppercase;
    color:var(--amber); opacity:.9; margin-bottom:22px;
  }
  .cap{
    font-size:clamp(13.5px, 1.05vw, 16px); line-height:1.72; color:var(--ink);
  }
  .cap::before{
    content:""; display:block; width:46px; height:1px; margin-bottom:18px;
    background:linear-gradient(90deg, var(--amber), transparent);
  }
  .cap p{ margin-bottom:1em; }
  .cap b{ color:var(--amber); font-weight:500; }
  .cap i.sl{ color:var(--slate); font-style:normal; }
  .cap i.rs{ color:var(--rose); font-style:normal; }
  .cap .plain{ color:var(--ink-dim); font-size:.88em; display:block; margin-top:.8em; font-style:italic; }
  .sline{ opacity:0; transform:translateY(8px); transition:opacity .9s ease, transform .9s ease; margin-bottom:1em; }
  .sline.show{ opacity:1; transform:none; }
  .sline .big{ font-size:1.35em; color:var(--amber); }

  /* ============ BEAT 0 · TITLE ============ */
  #beat0 .title{
    font-size:clamp(38px, 6.2vw, 80px); font-weight:500; text-align:center; line-height:1.08;
  }
  #beat0 .title em{ font-style:italic; color:var(--amber); }
  #beat0 .sub{
    margin-top:3vh; font-style:italic; color:var(--ink-dim); text-align:center;
    font-size:clamp(14px,1.5vw,18px); max-width:540px; line-height:1.6;
  }
  #titleStars{ position:absolute; inset:0; z-index:-1; opacity:.5; }

  /* ============ BEAT 1 · CORPUS ============ */
  #corpus{ max-width:720px; }
  #corpus p{
    font-size:clamp(17px, 2vw, 25px); line-height:1.8; text-align:center; margin:.7vh 0;
  }
  .w{ transition:color .25s, text-shadow .25s, opacity .25s; }
  .w.tracked{ cursor:pointer; }
  #corpus.focusing .w{ opacity:.22; }
  #corpus.focusing .w.lit{ opacity:1; color:var(--amber); text-shadow:0 0 18px rgba(217,160,91,.55); }

  /* ============ BEAT 2 · MATRIX ============ */
  #matrixwrap{ display:flex; flex-direction:column; align-items:center; max-width:100%; }
  #matrix{ display:grid; gap:2px; font-family:var(--sans); }
  #matrix .clab{
    writing-mode:vertical-rl; transform:rotate(206deg);
    font-size:10px; letter-spacing:.05em; color:var(--ink-dim);
    display:flex; align-items:center; padding-top:4px; height:62px;
  }
  #matrix .rlab{
    font-size:11px; letter-spacing:.05em; color:var(--ink-dim);
    display:flex; align-items:center; justify-content:flex-end; padding-right:9px;
    cursor:pointer; transition:color .25s; white-space:nowrap;
  }
  #matrix .rlab:hover, #matrix .rlab.hot{ color:var(--amber); }
  #matrix .rlab.echo{ color:var(--amber); text-shadow:0 0 14px rgba(217,160,91,.8); animation:pulse 1.1s ease infinite; }
  @keyframes pulse{ 0%,100%{opacity:1} 50%{opacity:.45} }
  #matrix .cell{
    width:clamp(12px, 1.5vw, 21px); height:clamp(12px, 1.5vw, 21px);
    background:rgba(234,228,211,.045); border-radius:2px;
    display:flex; align-items:center; justify-content:center;
    font-size:8.5px; color:rgba(234,228,211,.55);
    transition:background .25s, opacity .25s, box-shadow .25s;
  }
  #matrix .cell.c1{ background:rgba(217,160,91,.30); }
  #matrix .cell.c2{ background:rgba(217,160,91,.62); color:#07070d; }
  #matrix .cell.dimmed{ opacity:.16; }
  #matrix .cell.rowlit{ opacity:1; box-shadow:0 0 7px rgba(217,160,91,.3); }
  #simline{
    margin-top:2.2vh; font-style:italic; font-size:clamp(12.5px,1.2vw,15px);
    color:var(--ink-dim); min-height:1.6em; text-align:center;
  }
  #simline b{ color:var(--amber); font-weight:500; }

  /* ============ FLAT FIELD STATUS ============ */
  #epoch{
    position:fixed; bottom:6.5vh; left:var(--rail); right:0; z-index:12;
    font-family:var(--sans); font-size:10px; letter-spacing:.3em; text-transform:uppercase;
    color:var(--ink-dim); text-align:center; opacity:0; transition:opacity .5s, left .55s;
    pointer-events:none;
  }
  #epoch b{ color:var(--amber); font-weight:500; }

  /* ============ BEAT 11 · PAYOFF PROMPT ============ */
  #prompt{
    position:fixed; top:9vh; left:var(--rail); right:0; z-index:12; text-align:center;
    font-size:clamp(19px, 2.2vw, 30px); pointer-events:none;
    opacity:0; transition:opacity 1.2s ease, left .55s;
  }
  #prompt.show{ opacity:1; }
  #prompt .blank{
    display:inline-block; min-width:3.2em; border-bottom:1px solid rgba(234,228,211,.5);
    color:var(--amber); font-style:italic; transition:opacity .9s;
  }
  #prompt .blank span{ opacity:0; transition:opacity 1.1s ease; }
  #prompt .blank.filled span{ opacity:1; text-shadow:0 0 22px rgba(217,160,91,.7); }

  /* ============ CHROME ============ */
  .ui{ transition:opacity .45s ease; }
  body.clean .ui{ opacity:0 !important; pointer-events:none !important; }
  #dots{ position:fixed; bottom:2.1vh; left:calc(var(--rail) + (100vw - var(--rail))/2);
    transform:translateX(-50%); display:flex; gap:8px; z-index:40; transition:left .55s; }
  #dots button{ width:6.5px; height:6.5px; border-radius:50%; border:none; cursor:pointer;
    background:rgba(234,228,211,.18); padding:0; }
  #dots button.on{ background:var(--amber); box-shadow:0 0 8px rgba(217,160,91,.7); }
  #dots button:focus-visible{ outline:1px solid var(--amber); outline-offset:3px; }
  #hint{ position:fixed; bottom:2vh; right:2vw; z-index:40;
    font-family:var(--sans); font-size:10px; letter-spacing:.14em;
    color:var(--ink-dim); text-transform:uppercase; }
  #capbtn{ position:fixed; bottom:1.6vh; left:1.4vw; z-index:60;
    font-family:var(--sans); font-size:10px; letter-spacing:.18em; text-transform:uppercase;
    color:var(--ink-dim); background:rgba(10,9,19,.6); border:1px solid rgba(234,228,211,.18);
    border-radius:99px; padding:7px 13px; cursor:pointer;
    transition:opacity .4s, color .3s, border-color .3s; }
  #capbtn:hover{ color:var(--ink); border-color:rgba(234,228,211,.4); }
  body.clean #capbtn{ opacity:.12; }
  body.clean #capbtn:hover{ opacity:1; }
  #capbtn:focus-visible{ outline:1px solid var(--amber); outline-offset:2px; }
  .navzone{ position:fixed; top:0; bottom:8vh; width:7vw; z-index:30; border:none;
    background:none; cursor:pointer; color:transparent; font-size:30px; font-family:var(--serif); }
  .navzone:hover{ color:rgba(234,228,211,.3); }
  #zprev{ left:var(--rail); transition:left .55s; } #znext{ right:0; }

  @media (max-width:760px){
    :root{ --rail: clamp(220px, 38vw, 290px); }
    .railcard{ width:clamp(220px, 38vw, 290px); padding:4vh 20px 8vh; }
    .cap{ font-size:12px; line-height:1.6; }
  }
  @media (prefers-reduced-motion: reduce){
    .beat{ transition:opacity .2s; }
    .sline{ transition:opacity .3s; transform:none; }
  }
</style>
</head>
<body>

<div id="webgl" aria-label="3-D word galaxy. Drag to rotate."></div>
<canvas id="flat"></canvas>

<div id="stage">

  <!-- BEAT 0 · TITLE -->
  <section class="beat active" id="beat0">
    <canvas id="titleStars"></canvas>
    <div class="railcard">
      <div class="eyebrow">How a language model learns</div>
      <div class="cap"><p><b>→</b> and <b>←</b> move between beats.</p>
      <p><b>C</b> collapses this panel for a clean recording. <b>R</b> rescatters an animation.</p>
      <p>Drag the sky, once there is one.</p></div>
    </div>
    <h1 class="title">The Shape<br>of <em>Meaning</em></h1>
    <p class="sub">How structure nobody designed emerges<br>from more text than anybody could read.</p>
  </section>

  <!-- BEAT 1 · CORPUS -->
  <section class="beat" id="beat1">
    <div class="railcard">
      <div class="eyebrow">I · The corpus</div>
      <div class="cap"><p>Eight sentences. Pretend this is <em>everything</em> the system will ever see — no dictionary, no grammar lessons, no world. Only words, and the company they keep.</p>
      <p>Run your cursor over a word. In here it has no definition. It only has neighbors.</p></div>
    </div>
    <div id="corpus" class="hoverable"></div>
  </section>

  <!-- BEAT 2 · MATRIX -->
  <section class="beat" id="beat2">
    <div class="railcard">
      <div class="eyebrow">II · The count</div>
      <div class="cap"><p>Count which words share a sentence with which. Each row is a word's <em>fingerprint</em> — the record of its company.</p>
      <p>Hover <b>king</b>, then <b>queen</b>: two nearly identical rows. Nobody put that similarity there. It was already in the text, waiting to be counted.</p></div>
    </div>
    <div id="matrixwrap" class="hoverable">
      <div id="matrix"></div>
      <div id="simline">hover a word on the left</div>
    </div>
  </section>

  <!-- BEAT 3 · SETTLING -->
  <section class="beat" id="beat3">
    <div class="railcard">
      <div class="eyebrow">III · The settling</div>
      <div class="cap"><p>Scatter the words, then let the fingerprints act like forces: similar rows attract, different rows repel. The picture relaxes into the one layout that honors every fingerprint at once.</p>
      <p>Be clear about what this stands in for. A real model never sees the table — it plays a guessing game, <em>predict the hidden word</em>, and every miss nudges the positions. The forces here are a stand-in for that pressure. Same destination, different engine.</p>
      <p>Press <b>R</b>: new scatter, new picture — yet the same neighborhoods. The coordinates are arbitrary. Only the relations are real.</p>
      <span class="plain">Two separate training runs of the same model disagree in exactly this way.</span></div>
    </div>
  </section>

  <!-- BEAT 4 · FIRST ARROWS -->
  <section class="beat" id="beat4">
    <div class="railcard">
      <div class="eyebrow">IV · The first arrows</div>
      <div class="cap"><p>The settling bought something for free. <b>king</b> points to <b>queen</b> roughly the way <b>man</b> points to <b>woman</b> and <b>son</b> points to <b>daughter</b>. Nobody drew these arrows into the data. A relation has become a <em>direction</em>.</p>
      <p>Roughly, though. A flat page is a tight squeeze for this much structure; sometimes the arrows barely agree. Press <b>R</b> and watch them smear and re-form.</p>
      <p>Keep that complaint. It's about to matter.</p></div>
    </div>
  </section>

  <!-- BEAT 5 · CROWDING -->
  <section class="beat" id="beat5">
    <div class="railcard">
      <div class="eyebrow">V · The crowding</div>
      <div class="cap"><p>Feed it more text, and new words rain in, settling among their company — <b>prince</b> beside king, <b>Tokyo</b> beside the trains.</p>
      <p>But the page is filling. Some words need to sit near two crowds at once, and a flat sheet can't oblige: relations start fighting over the same few directions.</p>
      <p>The fix is not a bigger page. It's more <em>directions to differ in</em>.</p></div>
    </div>
  </section>

  <!-- BEAT 6 · THE LIFT -->
  <section class="beat" id="beat6">
    <div class="railcard">
      <div class="eyebrow">VI · The lift</div>
      <div class="cap">
        <div class="sline">So lift the constellation off the page. The flat picture was one plane of something deeper.</div>
        <div class="sline">You've watched 27 words settle. A real model settles a vocabulary of about <b>50,000</b> —</div>
        <div class="sline">— trained on <span class="big">500,000,000,000</span> words. More text than you could read in five thousand lifetimes.</div>
        <div class="sline">Every faint star joining the sky is a word, placed the same way. And real models don't stop at three dimensions — they use <em>thousands</em>. From here on, you're looking at a shadow. Drag it.</div>
      </div>
    </div>
  </section>

  <!-- BEAT 7 · ONE DIRECTION -->
  <section class="beat" id="beat7">
    <div class="railcard">
      <div class="eyebrow">VII · One direction</div>
      <div class="cap"><p>Re-find the arrows — in depth, where they have room.</p>
      <p><b>king→queen</b>, <b>man→woman</b>, <b>son→daughter</b>, <b>his→her</b>, <b>brother→sister</b>, <b>prince→princess</b>. Six arrows, one direction.</p>
      <p>The model was never told what gender is. It lies in the space as a direction. Drag to check that the agreement holds from every angle.</p></div>
    </div>
  </section>

  <!-- BEAT 8 · ANOTHER DIRECTION -->
  <section class="beat" id="beat8">
    <div class="railcard">
      <div class="eyebrow">VIII · Another direction</div>
      <div class="cap"><p>A different relation, a different direction.</p>
      <p><i class="sl">Paris→France</i>, <i class="sl">Rome→Italy</i>, <i class="sl">Tokyo→Japan</i>, <i class="sl">London→England</i>.</p>
      <p>Capital-to-country is its own path through the space — nowhere parallel to gender.</p></div>
    </div>
  </section>

  <!-- BEAT 9 · MANY PATHS -->
  <section class="beat" id="beat9">
    <div class="railcard">
      <div class="eyebrow">IX · Many paths</div>
      <div class="cap"><p>And one word sits on many paths at once. <b>king→queen</b> is one direction; <i class="rs">king→prince</i> is another.</p>
      <p>Every relation the text rehearses becomes a direction — and a word just <em>is</em> the crossing-point of all its relations. The full record of the company it keeps.</p></div>
    </div>
  </section>

  <!-- BEAT 10 · NEIGHBORHOODS -->
  <section class="beat" id="beat10">
    <div class="railcard">
      <div class="eyebrow">X · Neighborhoods</div>
      <div class="cap"><p>Pull back, and neighborhoods appear. The labels are <em>ours</em> — the model never learned the word "royalty." The clusters are <em>its</em>.</p>
      <p>They precipitated out of compression: the cheapest way to predict text turned out to be discovering what the text is about.</p>
      <p>Drag to a clear angle. The groupings survive any rotation.</p></div>
    </div>
  </section>

  <!-- BEAT 11 · PAYOFF -->
  <section class="beat" id="beat11">
    <div class="railcard">
      <div class="eyebrow">XI · The payoff</div>
      <div class="cap"><p>End where a language model begins: finish the sentence.</p>
      <p>Candidates glow by how well their company fits — and one small word, <em>her</em>, settles it. <b>queen</b> flares. <b>king</b>, right court, wrong company, only flickers.</p>
      <p>This is all the machine ever does, billions of times over — and everything you've seen is what that game builds. Meaning, in here, is the company a word keeps.</p>
      <p>Whether keeping company amounts to <em>understanding</em> — that's the next lesson.</p></div>
    </div>
  </section>

</div>

<div id="epoch"></div>
<div id="prompt">"The <span class="blank" id="blank">&nbsp;<span>queen</span>&nbsp;</span> ruled her kingdom from the castle."</div>

<nav id="dots" class="ui" aria-label="beats"></nav>
<div id="hint" class="ui">→ next · ← back · C panel · R replay</div>
<button id="capbtn" aria-label="toggle caption panel">Aa · panel</button>
<button class="navzone ui" id="zprev" aria-label="previous">‹</button>
<button class="navzone ui" id="znext" aria-label="next">›</button>

<script>
"use strict";
/* ════════════════════════════════════════════════════════════
   0 · DATA — corpus, co-occurrence, similarity
   ════════════════════════════════════════════════════════════ */
const BASE_SENTENCES = [
  "The king ruled his kingdom from the castle.",
  "The queen ruled her kingdom from the castle.",
  "The man told a story to his son.",
  "The woman told a story to her daughter.",
  "Paris is the capital of France.",
  "Rome is the capital of Italy.",
  "The train to Paris was late.",
  "The train to Rome was late."
];
const EXTRA_SENTENCES = [
  "The prince ruled his kingdom from the castle.",
  "The princess ruled her kingdom from the castle.",
  "The man told a story to his brother.",
  "The woman told a story to her sister.",
  "Tokyo is the capital of Japan.",
  "London is the capital of England.",
  "The train to Tokyo was late.",
  "The train to London was late."
];
const BASE_TRACKED = ["capital","castle","daughter","france","her","his","italy","king",
  "kingdom","man","paris","queen","rome","ruled","son","story","told","train","woman"];
const EXTRA_TRACKED = ["brother","england","japan","london","prince","princess","sister","tokyo"];
const FULL_TRACKED = BASE_TRACKED.concat(EXTRA_TRACKED);

function tokensOf(s){ return s.toLowerCase().replace(/[^a-z\s]/g,"").split(/\s+/).filter(Boolean); }
function buildStats(words, sentences){
  const idx=Object.fromEntries(words.map((w,i)=>[w,i])), n=words.length;
  const cooc=Array.from({length:n},()=>new Array(n).fill(0));
  for(const s of sentences){
    const tw=[...new Set(tokensOf(s).filter(w=>w in idx))];
    for(let a=0;a<tw.length;a++) for(let b=a+1;b<tw.length;b++){
      cooc[idx[tw[a]]][idx[tw[b]]]++; cooc[idx[tw[b]]][idx[tw[a]]]++; }
  }
  function cos(a,b){ let d=0,na=0,nb=0;
    for(let i=0;i<n;i++){ d+=cooc[a][i]*cooc[b][i]; na+=cooc[a][i]**2; nb+=cooc[b][i]**2; }
    return (na&&nb)? d/Math.sqrt(na*nb) : 0; }
  const sim=Array.from({length:n},(_,i)=>Array.from({length:n},(_,j)=> i===j?1:cos(i,j)));
  return {words, idx, cooc, sim, n};
}
const MSTAT = buildStats(BASE_TRACKED, BASE_SENTENCES);                 // matrix beat
const FSTAT = buildStats(FULL_TRACKED, BASE_SENTENCES.concat(EXTRA_SENTENCES));

function mulberry32(a){ return function(){ a|=0; a=a+0x6D2B79F5|0;
  let t=Math.imul(a^a>>>15,1|a); t=t+Math.imul(t^t>>>7,61|t)^t;
  return ((t^t>>>14)>>>0)/4294967296; }; }
const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;

function railWTarget(){ return document.body.classList.contains("clean") ? 0
  : Math.min(Math.max(290, innerWidth*0.28), 390); }

/* ════════════════════════════════════════════════════════════
   1 · BEAT MANAGER
   ════════════════════════════════════════════════════════════ */
const beats=[...document.querySelectorAll(".beat")], NB=beats.length;
let cur=0;
const onEnter={}, onExit={};
const dots=document.getElementById("dots");
beats.forEach((_,i)=>{ const b=document.createElement("button");
  b.addEventListener("click",()=>goTo(i)); b.setAttribute("aria-label","beat "+(i+1));
  dots.appendChild(b); });
function paintDots(){ [...dots.children].forEach((d,i)=>d.classList.toggle("on",i===cur)); }
function goTo(i){
  if(i<0||i>=NB||i===cur) return;
  (onExit[cur]||(()=>{}))();
  beats[cur].classList.remove("active");
  cur=i;
  beats[cur].classList.add("active");
  document.getElementById("webgl").classList.toggle("on", cur>=6);
  document.getElementById("flat").classList.toggle("on", cur>=3 && cur<=5);
  document.getElementById("epoch").style.opacity = (cur>=3&&cur<=5)?1:0;
  (onEnter[cur]||(()=>{}))();
  paintDots();
}
paintDots();
document.addEventListener("keydown",e=>{
  if(e.key==="ArrowRight"||e.key===" "){ e.preventDefault(); goTo(cur+1); }
  else if(e.key==="ArrowLeft"){ e.preventDefault(); goTo(cur-1); }
  else if(e.key==="c"||e.key==="C"){ toggleRail(); }
  else if(e.key==="r"||e.key==="R"){
    if(cur===3||cur===4) startSettle();
    else if(cur===5) startCrowd(true);
  }
});
document.getElementById("znext").addEventListener("click",()=>goTo(cur+1));
document.getElementById("zprev").addEventListener("click",()=>goTo(cur-1));
function toggleRail(){
  document.body.classList.toggle("clean");
  const on=!document.body.classList.contains("clean");
  document.getElementById("capbtn").textContent = on ? "Aa · panel" : "Aa · hidden";
}
document.getElementById("capbtn").addEventListener("click",toggleRail);

