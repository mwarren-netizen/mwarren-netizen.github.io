  rig.position.x=rigOffTarget();
  galaxy=new THREE.Group(); rig.add(galaxy);

  /* background starfield: clumped + diffuse, round soft points */
  const r=mulberry32(42);
  const COUNT = innerWidth<700 ? 3000 : 5600;
  const pos=new Float32Array(COUNT*3), col=new Float32Array(COUNT*3);
  const clumps=[];
  for(let i=0;i<14;i++){
    const th=r()*Math.PI*2, ph=Math.acos(2*r()-1), rad=28+r()*68;
    clumps.push({c:[rad*Math.sin(ph)*Math.cos(th), rad*Math.sin(ph)*Math.sin(th)*0.7, rad*Math.cos(ph)], s:5.5+r()*8});
  }
  const gauss=()=> (r()+r()+r()+r()-2)/1.2;
  const tc=new THREE.Color();
  for(let i=0;i<COUNT;i++){
    let p;
    if(r()<0.55){ const cl=clumps[i%clumps.length];
      p=[cl.c[0]+gauss()*cl.s, cl.c[1]+gauss()*cl.s, cl.c[2]+gauss()*cl.s]; }
    else { const th=r()*Math.PI*2, ph=Math.acos(2*r()-1), rad=20+Math.cbrt(r())*115;
      p=[rad*Math.sin(ph)*Math.cos(th), rad*Math.sin(ph)*Math.sin(th)*0.8, rad*Math.cos(ph)]; }
    pos.set(p,i*3);
    if(r()<0.12) tc.setHSL(0.085,0.55,0.62+r()*0.25);
    else         tc.setHSL(0.58+r()*0.08,0.25,0.62+r()*0.33);
    col.set([tc.r,tc.g,tc.b],i*3);
  }
  const geo=new THREE.BufferGeometry();
  geo.setAttribute("position",new THREE.BufferAttribute(pos,3));
  geo.setAttribute("color",new THREE.BufferAttribute(col,3));
  bgPoints=new THREE.Points(geo,new THREE.PointsMaterial({
    map:softDot(), size:2.1, sizeAttenuation:true, vertexColors:true, transparent:true,
    opacity:0, depthWrite:false, blending:THREE.AdditiveBlending }));
  galaxy.add(bgPoints);

  /* foreground word sprites (positions set during the lift) */
  for(const w of FULL_TRACKED){
    const sp=textSprite(w); sp.position.set(...RAW_POS[w]);
    galaxy.add(sp); fgSprites[w]=sp;
  }
  /* midground dim vocabulary */
  const jr=mulberry32(99);
  for(const w of MIDWORDS){
    const th=jr()*Math.PI*2, ph=Math.acos(2*jr()-1), rad=44+jr()*62;
    const sp=textSprite(w,{scale:2.9, color:"#b9b2a0"});
    sp.position.set(rad*Math.sin(ph)*Math.cos(th), rad*Math.sin(ph)*Math.sin(th)*0.75, rad*Math.cos(ph));
    galaxy.add(sp); midSprites.push(sp);
  }

  /* drag — listeners on window so nothing can eat them */
  let down=false, lx=0, ly=0;
  addEventListener("pointerdown",e=>{
    if(cur<6) return;
    if(e.target.closest("button")) return;
    down=true; lx=e.clientX; ly=e.clientY; homing=false;
    glHost.classList.add("dragging");
  });
  addEventListener("pointermove",e=>{ if(!down) return;
    rotVelY=(e.clientX-lx)*0.0032; rotVelX=(e.clientY-ly)*0.0022;
    lx=e.clientX; ly=e.clientY; });
  addEventListener("pointerup",()=>{ down=false; glHost.classList.remove("dragging"); });

  addEventListener("resize",()=>{ camera.aspect=innerWidth/innerHeight;
    camera.updateProjectionMatrix(); renderer.setSize(innerWidth,innerHeight); });

  threeReady=true;
  (function loop(){
    requestAnimationFrame(loop);
    if(homing){
      const dy=((homeY-rotY+Math.PI)%(2*Math.PI)+2*Math.PI)%(2*Math.PI)-Math.PI;
      rotY+=dy*0.035; rotX+=(homeX-rotX)*0.035;
    } else {
      rotY+=AUTOROT+rotVelY; rotX+=rotVelX;
      rotVelY*=0.93; rotVelX*=0.93;
      rotX=Math.max(-0.55,Math.min(0.55,rotX));
    }
    galaxy.rotation.y=rotY; galaxy.rotation.x=rotX;
    camZ+=(camZT-camZ)*0.04; camera.position.z=camZ;
    rig.position.x+=(rigOffTarget()-rig.position.x)*0.08;
    for(const f of fades) f.mat.opacity+=(f.t-f.mat.opacity)*0.06;
    for(let i=tweens.length-1;i>=0;i--){
      const tw=tweens[i]; tw.t=Math.min(1, tw.t+16/tw.dur);
      const e=tw.t<.5 ? 2*tw.t*tw.t : 1-Math.pow(-2*tw.t+2,2)/2;
      tw.sp.position.lerpVectors(tw.from,tw.to,e);
      if(tw.t>=1) tweens.splice(i,1);
    }
    if(cur===11 && fgSprites.queen){
      const s=1+0.07*Math.sin(performance.now()/280);
      const q=fgSprites.queen; q.scale.set(q.userData.bw*s, q.userData.bh*s, 1);
    }
    renderer.render(scene,camera);
  })();
}

/* — the lift: align settled 2D layout to the 3D configuration — */
function computeAlignment(){
  ensureFlatState(true);
  const wpp=worldPerPx(CAMZ0), off=rigOffTarget();
  const starts={};
  for(const n of phys.nodes){
    starts[n.w]=[(n.x-innerWidth/2)*wpp-off, -(n.y-innerHeight/2)*wpp];
  }
  const words=FULL_TRACKED;
  const A=words.map(w=>[RAW_POS[w][0],RAW_POS[w][1]]);     // targets (xy)
  const B=words.map(w=>starts[w]);                          // settled starts
  const mean=P=>P.reduce((m,p)=>[m[0]+p[0]/P.length, m[1]+p[1]/P.length],[0,0]);
  const mA=mean(A), mB=mean(B);
  const Ac=A.map(p=>[p[0]-mA[0],p[1]-mA[1]]), Bc=B.map(p=>[p[0]-mB[0],p[1]-mB[1]]);
  let best=null;
  for(const refl of [1,-1]){
    let num=0, den=0, na=0;
    for(let i=0;i<Ac.length;i++){
      const ax=refl*Ac[i][0], ay=Ac[i][1], bx=Bc[i][0], by=Bc[i][1];
      num+=ax*by-ay*bx; den+=ax*bx+ay*by; na+=ax*ax+ay*ay;
    }
    const th=Math.atan2(num,den);
    let s=(Math.cos(th)*den+Math.sin(th)*num)/na;
    s=Math.max(0.75,Math.min(1.3,s));
    let res=0;
    for(let i=0;i<Ac.length;i++){
      const ax=refl*Ac[i][0], ay=Ac[i][1];
      const rx=s*(ax*Math.cos(th)-ay*Math.sin(th)), ry=s*(ax*Math.sin(th)+ay*Math.cos(th));
      res+=(rx-Bc[i][0])**2+(ry-Bc[i][1])**2;
    }
    if(!best||res<best.res) best={refl,th,s,res};
  }
  T={};
  for(const w of words){
    const p=RAW_POS[w], ax=best.refl*(p[0]-mA[0]), ay=p[1]-mA[1];
    T[w]=new THREE.Vector3(
      best.s*(ax*Math.cos(best.th)-ay*Math.sin(best.th)),
      best.s*(ax*Math.sin(best.th)+ay*Math.cos(best.th)),
      best.s*p[2]);
  }
  return starts;
}
function buildDecorations(){
  if(arrowsBuilt) return;
  function mkArrow(a,b,color){
    const pa=T[a], pb=T[b];
    const dir=pb.clone().sub(pa); const len=dir.length();
    const ar=new THREE.ArrowHelper(dir.normalize(), pa, len-2.5, color, 3.2, 1.6);
    ar.line.material.transparent=true; ar.cone.material.transparent=true;
    ar.line.material.opacity=0; ar.cone.material.opacity=0;
    galaxy.add(ar); return ar;
  }
  arrowsA=FAM_A.map(([a,b])=>mkArrow(a,b,0xd9a05b));
  arrowsB=FAM_B.map(([a,b])=>mkArrow(a,b,0x7f9bb3));
  arrowsC=FAM_C.map(([a,b])=>mkArrow(a,b,0xc4798a));
  const gt=glowTex();
  for(const cl of CLUSTERS){
    const c=new THREE.Vector3();
    cl.members.forEach(w=>c.add(T[w])); c.multiplyScalar(1/cl.members.length);
    const mat=new THREE.SpriteMaterial({map:gt, color:cl.color, transparent:true,
      opacity:0, depthWrite:false, blending:THREE.AdditiveBlending});
    const g=new THREE.Sprite(mat); g.position.copy(c); g.scale.set(50,50,1);
    galaxy.add(g); glowSprites.push(g);
    const lb=textSprite(cl.name,{font:"600 38px ui-sans-serif, system-ui, sans-serif",
      color:"#"+cl.color.toString(16).padStart(6,"0"), scale:3.2});
    lb.position.set(c.x, c.y+16, c.z);
    galaxy.add(lb); clusterLabels.push(lb);
  }
  const qg=new THREE.SpriteMaterial({map:gt, color:0xd9a05b, transparent:true, opacity:0,
    depthWrite:false, blending:THREE.AdditiveBlending});
  queenGlow=new THREE.Sprite(qg); queenGlow.position.copy(T.queen); queenGlow.scale.set(16,16,1);
  galaxy.add(queenGlow);
  const kg=qg.clone(); kingGlow=new THREE.Sprite(kg); kingGlow.position.copy(T.king);
  kingGlow.scale.set(11,11,1); galaxy.add(kingGlow);
  for(const w of FULL_TRACKED){ const sp=fgSprites[w];
    sp.userData.bw=sp.scale.x; sp.userData.bh=sp.scale.y; }
  arrowsBuilt=true;
}
function doLift(instant){
  if(lifted){ return; }
  initThree();
  const starts=computeAlignment();
  buildDecorations();
  for(const w of FULL_TRACKED){
    const sp=fgSprites[w];
    const from=new THREE.Vector3(starts[w][0], starts[w][1], 0);
    if(instant||reduceMotion){ sp.position.copy(T[w]); }
    else { sp.position.copy(from);
      tweens.push({sp, from, to:T[w].clone(), t:-(Math.random()*0.18), dur:2600}); }
    fadeTo(sp.material, 0.95);
  }
  lifted=true;
}
function moodSky(){           // full galaxy view
  fadeTo(bgPoints.material,0.85);
  for(const w of FULL_TRACKED) fadeTo(fgSprites[w].material,0.95);
  for(const s of midSprites) fadeTo(s.material,0.2);
  for(const g of glowSprites) fadeTo(g.material,0);
  for(const l of clusterLabels) fadeTo(l.material,0);
  setArrows(arrowsA,0); setArrows(arrowsB,0); setArrows(arrowsC,0);
  if(queenGlow){ fadeTo(queenGlow.material,0); fadeTo(kingGlow.material,0); }
  camZT=CAMZ0; homing=false;
}
function setArrows(arr,t){ for(const a of arr){ fadeTo(a.line.material,t); fadeTo(a.cone.material,t); } }
function moodDirections(famSet, arrOn, arrFaint){
  fadeTo(bgPoints.material,0.07);
  for(const s of midSprites) fadeTo(s.material,0.02);
  for(const w of FULL_TRACKED){
    const focus=famSet.has(w);
    fadeTo(fgSprites[w].material, focus?0.95:(arrFaint&&SET_A.has(w)?0.4:0.06));
  }
  setArrows(arrowsA, arrOn===arrowsA?0.95:(arrFaint?0.3:0));
  setArrows(arrowsB, arrOn===arrowsB?0.95:0);
  setArrows(arrowsC, arrOn===arrowsC?0.95:0);
  for(const g of glowSprites) fadeTo(g.material,0);
  for(const l of clusterLabels) fadeTo(l.material,0);
  if(queenGlow){ fadeTo(queenGlow.material,0); fadeTo(kingGlow.material,0); }
  camZT=86; homing=false;
}

/* beat 6 — the lift + scale, staged caption lines */
onEnter[6]=()=>{
  initThree(); clearTimers();
  const lines=document.querySelectorAll("#beat6 .sline");
  lines.forEach(l=>l.classList.remove("show"));
  document.getElementById("prompt").classList.remove("show");
  if(lifted){ moodSky(); lines.forEach(l=>l.classList.add("show")); return; }
  const dl = reduceMotion ? [100,300,500,700] : [300,2400,4600,7400];
  beatTimers=[...lines].map((l,i)=>setTimeout(()=>l.classList.add("show"), dl[i]));
  beatTimers.push(setTimeout(()=>{ doLift(false); }, reduceMotion?100:500));
  beatTimers.push(setTimeout(()=>{                 // the sky arrives with the numbers
    fadeTo(bgPoints.material,0.85);
    for(const s of midSprites) fadeTo(s.material,0.2);
  }, reduceMotion?200:4600));
  camZT=CAMZ0; homing=false;
};
onExit[6]=clearTimers;

function ensureLifted(){ if(!lifted){ initThree(); doLift(true);
  fadeTo(bgPoints.material,0.85); for(const s of midSprites) fadeTo(s.material,0.2); } }

onEnter[7]=()=>{ ensureLifted(); moodDirections(SET_A, arrowsA, false); };
onEnter[8]=()=>{ ensureLifted(); moodDirections(SET_B, arrowsB, false); };
onEnter[9]=()=>{ ensureLifted(); moodDirections(SET_C, arrowsC, true); };

onEnter[10]=()=>{
  ensureLifted(); clearTimers();
  fadeTo(bgPoints.material,0.4);
  for(const w of FULL_TRACKED) fadeTo(fgSprites[w].material,0.85);
  for(const s of midSprites) fadeTo(s.material,0.05);
  setArrows(arrowsA,0); setArrows(arrowsB,0); setArrows(arrowsC,0);
  for(const g of glowSprites) fadeTo(g.material,0.55);
  fadeTo(queenGlow.material,0); fadeTo(kingGlow.material,0);
  camZT=120; homing=false;
  beatTimers=[setTimeout(()=>{ for(const l of clusterLabels) fadeTo(l.material,0.9); },
    reduceMotion?300:3000)];
};
onExit[10]=clearTimers;

onEnter[11]=()=>{
  ensureLifted(); clearTimers();
  fadeTo(bgPoints.material,0.1);
  for(const s of midSprites) fadeTo(s.material,0.015);
  setArrows(arrowsA,0); setArrows(arrowsB,0); setArrows(arrowsC,0);
  for(const g of glowSprites) fadeTo(g.material,0);
  for(const l of clusterLabels) fadeTo(l.material,0);
  const royal=new Set(CLUSTERS[0].members);
  for(const w of FULL_TRACKED)
    fadeTo(fgSprites[w].material, w==="queen"?1 : royal.has(w)?0.65 : 0.06);
  /* home the camera on the royal court */
  const q=T.queen.clone().add(T.king).multiplyScalar(0.5);
  const r=Math.hypot(q.x,q.z);
  homeY=Math.atan2(-q.x,q.z); homeX=Math.max(-0.6,Math.min(0.6,Math.atan2(q.y,r)));
  homing=true; camZT=Math.max(58, q.length()+44);
  const blank=document.getElementById("blank");
  blank.classList.remove("filled");
  document.getElementById("prompt").classList.add("show");
  beatTimers=[ setTimeout(()=>{
      blank.classList.add("filled");
      fadeTo(queenGlow.material,0.8); fadeTo(kingGlow.material,0.22);
    }, reduceMotion?500:3200) ];
};
onExit[11]=()=>{ clearTimers(); homing=false;
  document.getElementById("prompt").classList.remove("show");
  if(fgSprites.queen&&fgSprites.queen.userData.bw){
    const q=fgSprites.queen; q.scale.set(q.userData.bw,q.userData.bh,1); } };

/* warm the GPU early */
setTimeout(()=>{ try{ initThree(); }catch(e){ console.error(e); } }, 1400);
</script>
