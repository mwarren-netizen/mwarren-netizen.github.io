/* ════════════════════════════════════════════════════════════
   3 · BEAT 1 — corpus hover
   ════════════════════════════════════════════════════════════ */
(function(){
  const box=document.getElementById("corpus");
  const idx=Object.fromEntries(BASE_TRACKED.map(w=>[w,1]));
  for(const s of BASE_SENTENCES){
    const p=document.createElement("p");
    s.split(/(\s+)/).forEach(part=>{
      if(/^\s+$/.test(part)){ p.appendChild(document.createTextNode(part)); return; }
      const clean=part.toLowerCase().replace(/[^a-z]/g,"");
      const span=document.createElement("span");
      span.className="w"+(clean in idx?" tracked":"");
      span.dataset.w=clean; span.textContent=part;
      p.appendChild(span);
    });
    box.appendChild(p);
  }
  box.addEventListener("mouseover",e=>{
    const t=e.target.closest(".w.tracked"); if(!t) return;
    box.classList.add("focusing");
    box.querySelectorAll(".w").forEach(w=>w.classList.toggle("lit", w.dataset.w===t.dataset.w));
  });
  box.addEventListener("mouseleave",()=>{ box.classList.remove("focusing");
    box.querySelectorAll(".w.lit").forEach(w=>w.classList.remove("lit")); });
})();

/* ════════════════════════════════════════════════════════════
   4 · BEAT 2 — co-occurrence matrix
   ════════════════════════════════════════════════════════════ */
(function(){
  const {words,cooc,sim,n}=MSTAT;
  const m=document.getElementById("matrix"), simline=document.getElementById("simline");
  m.style.gridTemplateColumns=`auto repeat(${n}, auto)`;
  m.appendChild(document.createElement("div"));
  words.forEach(w=>{ const d=document.createElement("div"); d.className="clab"; d.textContent=w; m.appendChild(d); });
  const rows=[];
  words.forEach((w,i)=>{
    const lab=document.createElement("div"); lab.className="rlab"; lab.textContent=w; lab.dataset.i=i;
    m.appendChild(lab);
    const cells=[];
    for(let j=0;j<n;j++){
      const c=document.createElement("div"), v=cooc[i][j];
      c.className="cell"+(v>=2?" c2":v===1?" c1":"");
      if(v>0) c.textContent=v;
      m.appendChild(c); cells.push(c);
    }
    rows.push({lab,cells});
  });
  function clear(){ simline.textContent="hover a word on the left";
    rows.forEach(r=>{ r.lab.classList.remove("hot","echo");
      r.cells.forEach(c=>c.classList.remove("dimmed","rowlit")); }); }
  m.addEventListener("mouseover",e=>{
    const lab=e.target.closest(".rlab"); if(!lab) return;
    const i=+lab.dataset.i; let best=-1,bs=-1;
    for(let j=0;j<n;j++) if(j!==i&&sim[i][j]>bs){ bs=sim[i][j]; best=j; }
    rows.forEach((r,k)=>{
      r.lab.classList.toggle("hot",k===i); r.lab.classList.toggle("echo",k===best);
      r.cells.forEach(c=>{ c.classList.toggle("rowlit",k===i||k===best);
                           c.classList.toggle("dimmed",k!==i&&k!==best); });
    });
    simline.innerHTML=`closest fingerprint to <b>${words[i]}</b>: <b>${words[best]}</b> · ${(bs*100).toFixed(0)}% match`;
  });
  m.addEventListener("mouseleave",clear);
})();

